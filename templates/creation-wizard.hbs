<form class="a2e-wizard-form" autocomplete="off">
  <ol class="wizard-progress">{{#each steps}}<li data-step-label>{{this}}</li>{{/each}}</ol>
  <section data-wizard-step="0"><h2>Campaign Profile</h2><div class="wizard-fields"><label>Campaign<input name="campaign"></label><label>Technology Era<select name="techEra">{{#each (a2eRange 1 9)}}<option value="{{this}}" {{#if (a2eEq this 7)}}selected{{/if}}>TE {{this}}</option>{{/each}}</select></label><label>Point-buy budget<select name="pointBuy"><option>12</option><option>15</option><option>18</option></select></label><label>Maximum restriction<select name="restriction"><option value="G">General</option><option value="R" selected>Restricted</option><option value="M">Military</option><option value="X">Experimental</option></select></label></div><button type="button" data-wizard-import><i class="fas fa-file-import"></i> Import a Hero Forge character instead</button></section>
  <section data-wizard-step="1"><h2>Identity</h2><div class="wizard-fields"><label>Character name<input name="name" value="{{actor.name}}"></label><label>Player<input name="player" value="{{actor.system.identity.player}}"></label><label>Concept<textarea name="concept">{{actor.system.identity.concept}}</textarea></label></div></section>
  <section data-wizard-step="2"><h2>Abilities</h2><p>Set the six ability scores using the campaign point-buy budget.</p><div class="wizard-fields">{{#each abilities}}<label>{{name}}<span class="a2e-stepper"><button type="button" data-wizard-adjust data-field="ability.{{id}}" data-delta="-1">−</button><input type="text" inputmode="numeric" min="3" max="7" name="ability.{{id}}" value="{{value}}" readonly><button type="button" data-wizard-adjust data-field="ability.{{id}}" data-delta="1">+</button></span></label>{{/each}}</div></section>
  <section data-wizard-step="3"><h2>Species and Archetype</h2><div class="wizard-fields"><label>Species<select name="species">{{#each species}}<option value="{{id}}">{{name}} (p. {{page}})</option>{{/each}}</select></label><label>Archetype<select name="archetype"><option value="">Choose…</option>{{#each archetypes}}<option value="{{id}}">{{name}}</option>{{/each}}</select></label><label>Mandated entry talent<select name="mandatedTalent"><option value="">Choose…</option>{{#each talentRoots}}<option value="{{id}}">{{name}} — {{constellation}}</option>{{/each}}</select></label></div></section>
  <section data-wizard-step="4"><h2>Skills</h2><p>Spend 35 ranks. Each archetype requires at least one rank-4 skill in every category.</p>{{#each skillGroups}}<details open><summary>{{name}}</summary><div class="wizard-list">{{#each rows}}<label><span>{{name}} <small>{{ability}}</small></span><span class="a2e-stepper"><button type="button" data-wizard-adjust data-field="skill.{{id}}" data-delta="-1">−</button><input type="text" inputmode="numeric" min="0" max="5" name="skill.{{id}}" value="0" readonly><button type="button" data-wizard-adjust data-field="skill.{{id}}" data-delta="1">+</button></span></label>{{/each}}</div></details>{{/each}}</section>
  <section data-wizard-step="5"><h2>Starting Talents</h2><p>Choose three entry talents. Check the same talent selected as your archetype’s mandated talent.</p><div class="wizard-list">{{#each talentRoots}}<label><input type="checkbox" name="talents" value="{{id}}"><span><b>{{name}}</b><small>{{constellation}} · p. {{page}}</small></span></label>{{/each}}</div></section>
  <section data-wizard-step="6"><h2>Starting Gear</h2><p>Choose six quick-pick items: at least one weapon, one armor, one tool or drone, and three additional weapons or tools allowed by the campaign.</p>{{#each gearGroups}}<details><summary>{{name}}</summary><div class="wizard-list">{{#each rows}}<label><input type="checkbox" name="gear" value="{{id}}"><span><b>{{name}}</b><small>TE {{techEra}} · Class {{class}} {{restriction}} · {{mass}} kg</small></span></label>{{/each}}</div></details>{{/each}}</section>
  <section data-wizard-step="7"><h2>Review and Create</h2><p>The wizard will verify identity, archetype choices, all 35 skill ranks, five mandated skill categories, and three starting talents. Any remaining campaign-specific choices can be edited on the character sheet.</p></section>
  <footer class="wizard-actions"><button type="button" data-wizard-back>Back</button><button type="button" data-wizard-next>Next</button><button type="button" data-wizard-finish>Create / Update Hero</button></footer>
</form>
