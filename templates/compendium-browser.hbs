<section class="catalog-browser-body"><div class="catalog-controls"><input data-catalog-search type="search" placeholder="Search names, categories, rules, and descriptions"><select data-catalog-type><option value="">All types</option>{{#each types}}<option value="{{this}}">{{this}}</option>{{/each}}</select><select data-catalog-actor><option value="">Add to Actor…</option>{{#each actors}}<option value="{{id}}">{{name}}</option>{{/each}}</select></div><div class="catalog-results">{{#each rows}}<article data-catalog-row data-type="{{type}}" data-search="{{search}}"><div><b>{{name}}</b><small>{{type}} · {{category}} · Core p. {{system.page}}</small><p>{{{system.description}}}</p></div><button type="button" data-catalog-add="{{type}}:{{system.sourceId}}">Add</button></article>{{/each}}</div></section>
