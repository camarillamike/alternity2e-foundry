<form class="{{cssClass}} a2e-sheet" autocomplete="off">
  <header class="a2e-header"><img src="{{actor.img}}" data-edit="img" title="{{actor.name}}"><div><input class="a2e-name" name="name" value="{{actor.name}}"><p>Level {{system.level}} · {{actor.type}} · TE {{system.campaign.techEra}} {{#if system.build.locked}}· Build locked{{/if}}</p></div><div class="header-actions">{{#if isHero}}{{#if access.canConfigure}}<button type="button" data-action="creationWizard"><i class="fas fa-list-check"></i> Creator</button>{{/if}}<button type="button" data-action="importCharacter"><i class="fas fa-file-import"></i> Import</button>{{/if}}<button type="button" data-action="exportCharacter"><i class="fas fa-file-export"></i> Export</button>{{#if access.isGM}}<button type="button" data-action="toggleBuildLock">{{#if system.build.locked}}Unlock build{{else}}Lock build{{/if}}</button>{{/if}}</div></header>
  <section class="a2e-summary"><div><strong>{{system.derived.initiative.target}}</strong>Initiative target</div><div><strong>{{system.derived.speed}} m</strong>Current speed</div><div><strong>{{load.mass}} / {{load.capacity}} kg</strong>{{load.label}}</div><div><strong>{{system.derived.woundPenalty}}</strong>Wound steps</div><div><strong>{{system.derived.armor.physical}} / {{system.derived.armor.energy}}</strong>Armor P/E</div></section>
  <nav class="tabs" data-group="primary"><a class="item" data-tab="play">Play</a><a class="item" data-tab="build">Character</a><a class="item" data-tab="items">Items</a><a class="item" data-tab="advance">Advancement</a><a class="item" data-tab="notes">Notes</a></nav>
  <section class="tab" data-group="primary" data-tab="play"><div class="a2e-grid">
    <article class="panel"><h2>Round {{system.play.round}} · Impulse {{system.play.impulse}}/8</h2><p>The GM controls the shared encounter and scene clock.</p>{{#if access.canAdvanceClock}}<button type="button" data-action="nextImpulse">Advance impulse</button><button type="button" data-action="newScene">New scene</button>{{/if}}<h3>Hero Points: {{system.heroPoints}}</h3>{{#if access.canSpendHeroPoints}}<div class="hero-actions"><button type="button" data-action="useHeroPoint" data-effect="immediateAction">Immediate action</button><button type="button" data-action="useHeroPoint" data-effect="improveCheck">Improve last noncombat check</button><button type="button" data-action="useHeroPoint" data-effect="severeToLight">Critical/mortal → light</button><button type="button" data-action="useHeroPoint" data-effect="lesserToGraze">Light/moderate/serious → graze</button><button type="button" data-action="useHeroPoint" data-effect="luckyBreak">Request lucky break</button></div>{{/if}}{{#if access.canAward}}<button type="button" data-action="awardHeroPoint" data-amount="1">Award Hero Point</button>{{/if}}</article>
    <article class="panel combat-actions"><h2>Action Scheduler</h2>{{#if combatState.active}}<p class="combat-schedule {{#if combatState.ready}}ready{{/if}}">{{#if combatState.readied}}Readied action available{{else}}{{#if combatState.ready}}Ready now{{else}}Next action: Round {{combatState.nextRound}}, Impulse {{combatState.nextImpulse}}{{/if}}{{/if}}<br><small>{{combatState.lastAction}}</small></p>{{#if combatState.modifier}}<p class="pending-modifier">Pending: <b>{{combatState.modifier.label}}</b></p>{{/if}}{{#if access.canPlay}}<label>Ready trigger<input name="readyTrigger" placeholder="When the guard opens the door..."></label><div class="action-cost-grid"><button type="button" data-action="scheduleAction" data-kind="interact" data-cost="1" data-label="Interact">Interact <small>1</small></button><button type="button" data-action="scheduleAction" data-kind="reposition" data-cost="1" data-label="Reposition">Reposition <small>1</small></button><button type="button" data-action="scheduleAction" data-kind="resist" data-cost="1" data-label="Resist">Resist <small>1</small></button><button type="button" data-action="scheduleAction" data-kind="move" data-cost="2" data-label="Move">Move <small>2</small></button><button type="button" data-action="scheduleAction" data-kind="totalDefense" data-cost="3" data-label="Total Defense">Total Defense <small>3</small></button><button type="button" data-action="scheduleAction" data-kind="nothing" data-cost="1" data-label="Do Nothing">Wait <small>1</small></button><button type="button" data-action="scheduleAction" data-kind="ready" data-cost="1" data-label="Ready Action">Ready <small>1</small></button><button type="button" data-action="react">Reaction <small>+1</small></button></div><h3>Next-action modifier</h3><div class="modifier-grid"><button type="button" data-action="setCombatModifier" data-modifier="aim">Aim</button><button type="button" data-action="setCombatModifier" data-modifier="burst">Burst</button><button type="button" data-action="setCombatModifier" data-modifier="fullauto">Full Auto</button><button type="button" data-action="setCombatModifier" data-modifier="charge">Charge</button><button type="button" data-action="setCombatModifier" data-modifier="evade">Evade</button><button type="button" data-action="setCombatModifier" data-modifier="concentrate1">Concentrate +1</button><button type="button" data-action="setCombatModifier" data-modifier="concentrate2">Concentrate +2</button></div>{{/if}}{{else}}<p>Add this Actor to an active encounter to use rulebook action scheduling.</p>{{/if}}</article>
    <article class="panel"><h2>Damage and Recovery</h2>{{#if access.canDamage}}<div class="damage-form"><input name="damage" type="number" min="0" value="0"><select name="damageType"><option value="physical">Physical</option><option value="energy">Energy</option><option value="other">Other</option></select><button type="button" data-action="applyDamage">Apply</button></div>{{/if}}{{#if system.play.lastDamage}}<p>{{system.play.lastDamage.raw}} − {{system.play.lastDamage.resistance}} armor = <strong>{{system.play.lastDamage.final}} {{system.play.lastDamage.severity}}</strong>{{#if system.play.lastDamage.shieldAbsorbed}} · Force Shield absorbed {{system.play.lastDamage.shieldAbsorbed}}{{/if}}</p>{{/if}}{{#if access.isGM}}<div class="recovery-actions"><button type="button" data-action="recover" data-period="scene">Clear grazes</button><button type="button" data-action="recover" data-period="day">Clear lights</button><button type="button" data-action="undoDamage">Undo last damage</button></div>{{/if}}{{#if mortality.active}}<h3>Mortal wound challenge</h3><p>{{mortality.lethality}} · {{mortality.successes}} successes / {{mortality.failures}} failures · {{mortality.strikes}} strikes · next {{mortality.interval}}</p>{{#if access.canPlay}}<button type="button" data-action="rollMortality">Roll Resilience</button>{{/if}}{{#if access.isGM}}<span class="medicine-successes">Medicine successes: <button type="button" data-action="stabilizeMortality" data-successes="1">+1</button><button type="button" data-action="stabilizeMortality" data-successes="2">+2</button><button type="button" data-action="stabilizeMortality" data-successes="3">+3</button></span>{{/if}}{{/if}}{{#each recovery}}<p>{{row}} recovery: {{days}} day(s) {{#if ../access.canPlay}}<button type="button" data-action="rollRecovery" data-recovery-id="{{id}}">Resolve</button>{{/if}}</p>{{/each}}</article>
    <article class="panel wounds span-2"><h2>Armor and Damage</h2><p>Armor reduces physical by <b>{{system.derived.armor.physical}}</b>, energy by <b>{{system.derived.armor.energy}}</b>.</p>{{#each wounds}}<div class="wound-row"><b>{{range}}</b><span>{{label}}</span><span class="wound-boxes">{{#each boxes}}<button type="button" class="wound-box {{#if marked}}marked{{/if}}" data-action="toggleWound" data-row="{{../id}}" data-index="{{index}}"></button>{{/each}}</span>{{#if recoverable}}{{#if ../access.isGM}}<button type="button" data-action="scheduleRecovery" data-row="{{id}}">Schedule recovery</button>{{/if}}{{/if}}</div>{{/each}}</article>
    <article class="panel"><h2>Attacks</h2>{{#each attacks}}<div class="attack-row {{#unless system.equipped}}unequipped{{/unless}}"><button type="button" class="item-roll" data-action="rollWeapon" data-item-id="{{id}}"><span><b>{{name}}</b><small>{{system.range}} · Speed {{system.speed}} · {{system.special}}</small></span><span>{{system.damage}} {{system.damageType}}</span></button><div class="attack-controls"><button type="button" data-action="toggleEquip" data-item-id="{{id}}">{{#if system.equipped}}Equipped{{else}}Stowed{{/if}}</button><button type="button" data-action="editItem" data-item-id="{{id}}"><i class="fas fa-pen"></i></button><button type="button" data-action="deleteItem" data-item-id="{{id}}"><i class="fas fa-trash"></i></button></div>{{#if system.ammo.max}}<div class="ammo-panel"><div class="ammo"><span><b>Loaded {{system.ammo.value}}/{{system.ammo.max}}</b> · Reload {{system.ammo.reloadCost}} impulse{{#unless (a2eEq system.ammo.reloadCost 1)}}s{{/unless}}</span><button type="button" data-action="reload" data-item-id="{{id}}">Reload</button></div><div class="ammo-options"><label>Reserve ({{system.ammo.reserveUnit}})<span class="quantity-control"><button type="button" data-action="adjustReserve" data-item-id="{{id}}" data-delta="-1">−</button><b>{{system.ammo.reserve}}</b><button type="button" data-action="adjustReserve" data-item-id="{{id}}" data-delta="1">+</button></span></label>{{#if (a2eEq system.sourceId "revolver")}}<button type="button" data-action="toggleSpeedLoader" data-item-id="{{id}}">Speed loader: {{#if system.ammo.speedLoader}}Yes{{else}}No{{/if}}</button>{{/if}}{{#if (a2eEq system.ammo.mode "loadout")}}<label>Loaded payload<input data-ammo-payload data-item-id="{{id}}" value="{{system.ammo.payload}}"></label>{{/if}}<label>Ammo type<select data-ammo-type data-item-id="{{id}}"><option value="normal" {{#if (a2eEq system.ammo.specialType "normal")}}selected{{/if}}>Normal</option><option value="armorPiercing" {{#if (a2eEq system.ammo.specialType "armorPiercing")}}selected{{/if}}>Armor Piercing</option><option value="hollowPoint" {{#if (a2eEq system.ammo.specialType "hollowPoint")}}selected{{/if}}>Hollow Point</option><option value="incendiary" {{#if (a2eEq system.ammo.specialType "incendiary")}}selected{{/if}}>Incendiary</option><option value="detoMax" {{#if (a2eEq system.ammo.specialType "detoMax")}}selected{{/if}}>Deto-Max</option></select></label><button type="button" data-action="toggleSpecialSupply" data-item-id="{{id}}">Special supply: {{#if system.ammo.specialAvailable}}Available{{else}}None{{/if}}</button></div></div>{{/if}}</div>{{else}}<p>Drag weapons here from the Weapons compendium.</p>{{/each}}</article>
    <article class="panel"><h2>Conditions and Timed Effects</h2><div class="status-grid">{{#each statuses}}<button type="button" class="status {{#if active}}active{{/if}}" data-action="toggleStatus" data-status="{{id}}">{{label}}</button>{{/each}}</div>{{#each effects}}<div class="effect-row"><b>{{source}}</b><span>{{status}} · {{durationType}}{{#if expiresTick}} to tick {{expiresTick}}{{/if}} · resist {{resistSkill}} {{progress}}/{{required}}</span>{{#if ../access.canPlay}}<button type="button" data-action="resistEffect" data-effect-id="{{id}}">Resist</button>{{/if}}{{#if ../access.isGM}}<button type="button" data-action="removeEffect" data-effect-id="{{id}}">Remove</button>{{/if}}</div>{{/each}}{{#if access.isGM}}<div class="effect-builder"><input name="effectSource" placeholder="Effect source"><select name="effectStatus"><option value="blinded">Blinded</option><option value="dazed">Dazed</option><option value="distracted">Distracted</option><option value="grappled">Grappled</option><option value="impaired">Impaired</option><option value="slowed">Slowed</option><option value="stun">Stun</option><option value="weakened">Weakened</option><option value="damage-over-time">Damage over time</option></select><select name="effectDuration"><option value="impulses">Impulses</option><option value="scene">Scene</option><option value="resist">Active resist</option><option value="passive">Passive resist</option></select><input name="effectImpulses" type="text" inputmode="numeric" value="3"><input name="effectResist" placeholder="Resist skill"><input name="effectRequired" type="text" inputmode="numeric" value="1"><select name="effectDamage"><option value="graze">Graze</option><option value="light">Light</option><option value="moderate">Moderate</option><option value="serious">Serious</option></select><button type="button" data-action="addEffect">Add effect</button></div>{{/if}}</article>
    <article class="panel span-2"><h2>Challenge Trackers</h2>{{#each challenges}}<div class="challenge-row"><b>{{name}}</b><span>{{successes}}/{{target}} successes · {{failures}}/{{failureLimit}} failures · {{interval}}</span>{{#if ../access.canPlay}}<button type="button" data-action="rollChallenge" data-challenge-id="{{id}}">Roll {{skillId}}</button>{{/if}}{{#if ../access.isGM}}<button type="button" data-action="advanceChallenge" data-challenge-id="{{id}}" data-degree="Average">+1</button><button type="button" data-action="advanceChallenge" data-challenge-id="{{id}}" data-degree="Excellent">+2</button><button type="button" data-action="advanceChallenge" data-challenge-id="{{id}}" data-degree="Stellar">+3</button><button type="button" data-action="advanceChallenge" data-challenge-id="{{id}}" data-degree="Failure">Failure</button>{{/if}}</div>{{else}}<p>No active challenges.</p>{{/each}}{{#if access.isGM}}<div class="challenge-builder"><input name="challengeName" placeholder="Challenge name"><input name="challengeSkill" placeholder="Skill id"><input name="challengeTarget" type="text" inputmode="numeric" value="3"><input name="challengeFailures" type="text" inputmode="numeric" value="3"><input name="challengeInterval" value="1 action"><label><input name="challengeSecret" type="checkbox"> Secret</label><button type="button" data-action="addChallenge">Add challenge</button></div>{{/if}}</article>
    <article class="panel span-2"><h2>Skill Checks</h2>{{#each skillGroups}}<details open><summary>{{name}}</summary>{{#each rows}}<button type="button" class="item-roll" data-action="rollSkill" data-item-id="{{item.id}}"><span><b>{{item.name}}</b><small>{{item.system.keyAbility}} · {{item.system.ranks}} ranks</small></span><span>Target {{target}} · {{steps}} steps</span></button>{{/each}}</details>{{/each}}</article>
  </div></section>
  <section class="tab" data-group="primary" data-tab="build"><div class="a2e-grid">
    {{#if isCreature}}<article class="panel span-2"><h2>Creature Profile</h2><p><b>{{system.creature.level}}</b> · {{system.creature.habitat}} · movement {{system.creature.movement}}</p>{{#if access.showPrivate}}<label>Threat level<input name="system.creature.level" value="{{system.creature.level}}"></label><label>Habitat<input name="system.creature.habitat" value="{{system.creature.habitat}}"></label><label>Senses<input name="system.creature.senses" value="{{system.creature.senses}}"></label><label>Movement<input name="system.creature.movement" value="{{system.creature.movement}}"></label><label>Behavior<textarea name="system.creature.behavior">{{system.creature.behavior}}</textarea></label><label>Special abilities<textarea name="system.creature.specialAbilities">{{system.creature.specialAbilities}}</textarea></label><label>Loot<textarea name="system.creature.loot">{{system.creature.loot}}</textarea></label>{{/if}}</article>{{/if}}
    {{#if isNpc}}<article class="panel span-2"><h2>GM NPC Profile</h2><p><b>{{system.npc.role}}</b> · attitude {{system.npc.attitude}} · initiative group {{system.npc.initiativeGroup}}</p><button type="button" data-action="rollNpcKey">Key skill {{system.npc.keyTarget}}+</button><button type="button" data-action="rollNpcSecondary">Secondary {{system.npc.secondaryTarget}}+</button>{{#if access.showPrivate}}<label>Role<input name="system.npc.role" value="{{system.npc.role}}"></label><label>Attitude<input name="system.npc.attitude" value="{{system.npc.attitude}}"></label><button type="button" data-action="shiftAttitude" data-delta="-1">Worsen attitude</button><button type="button" data-action="shiftAttitude" data-delta="1">Improve attitude</button><label>Initiative group<input name="system.npc.initiativeGroup" value="{{system.npc.initiativeGroup}}"></label><label>Key skill<input name="system.npc.keySkill" value="{{system.npc.keySkill}}"></label><label>Key target<input name="system.npc.keyTarget" value="{{system.npc.keyTarget}}"></label><label>Secondary target<input name="system.npc.secondaryTarget" value="{{system.npc.secondaryTarget}}"></label><label>Motive<textarea name="system.npc.motive">{{system.npc.motive}}</textarea></label><label>Tactics<textarea name="system.npc.tactics">{{system.npc.tactics}}</textarea></label><label>Private notes<textarea name="system.npc.privateNotes">{{system.npc.privateNotes}}</textarea></label>{{/if}}</article>{{/if}}
    {{#if isDrone}}<article class="panel span-2"><h2>Drone Control</h2><label>Controller Actor ID<input name="system.drone.controllerId" value="{{system.drone.controllerId}}"></label><label>Command<select name="system.drone.command"><option value="">Choose…</option>{{#each droneCommands}}<option value="{{name}}" {{#if (a2eEq name ../system.drone.command)}}selected{{/if}}>{{name}} (TE {{techEra}})</option>{{/each}}</select></label>{{#if access.canPlay}}<button type="button" data-action="droneCommand">Issue command (3 impulses; 2 with Drone Expert)</button>{{/if}}<p>{{system.drone.availableCommands}}</p><label>Range<input name="system.drone.range" value="{{system.drone.range}}"></label><label>Duration remaining<input name="system.drone.durationRemaining" value="{{system.drone.durationRemaining}}"></label><label><input type="checkbox" name="system.drone.autonomous" {{#if system.drone.autonomous}}checked{{/if}}> Autonomous</label></article>{{/if}}
    {{#if isVehicle}}<article class="panel span-2"><h2>Vehicle Operations</h2><p><b>{{system.vehicle.controlState}}</b> · {{system.vehicle.positionMode}} position · range {{system.vehicle.relativeRange}}</p>{{#if access.canPlay}}<button type="button" data-action="vehicleControl">Control vehicle (3 impulses)</button>{{/if}}{{#if access.showPrivate}}<label>Operator<input name="system.vehicle.operatorId" value="{{system.vehicle.operatorId}}"></label><label>Position mode<input name="system.vehicle.positionMode" value="{{system.vehicle.positionMode}}"></label><label>Relative range<input name="system.vehicle.relativeRange" value="{{system.vehicle.relativeRange}}"></label><label>Control state<input name="system.vehicle.controlState" value="{{system.vehicle.controlState}}"></label><label>Ram damage<input name="system.vehicle.ramDamage" value="{{system.vehicle.ramDamage}}"></label><label>Occupant cover<input name="system.vehicle.cover" value="{{system.vehicle.cover}}"></label><label>Environment<textarea name="system.vehicle.environment">{{system.vehicle.environment}}</textarea></label>{{/if}}</article>{{/if}}
    {{#if isStarship}}<article class="panel span-2"><h2>Starship Resource</h2><p>The Core book treats ships as resources and sets; occasional combat uses vehicle rules. Full construction and ship combat require <i>Shipyard</i>.</p><label>Hull<input name="system.starship.hull" value="{{system.starship.hull}}"></label><label>Drive<input name="system.starship.drive" value="{{system.starship.drive}}"></label><label>Modules<textarea name="system.starship.modules">{{system.starship.modules}}</textarea></label><label>Features<textarea name="system.starship.features">{{system.starship.features}}</textarea></label><label>Campaign notes<textarea name="system.starship.notes">{{system.starship.notes}}</textarea></label></article>{{/if}}
    <article class="panel"><h2>Abilities</h2>{{#each abilities}}<div class="a2e-stepper"><span>{{label}}</span>{{#if ../access.canConfigure}}<button type="button" data-action="adjustAbility" data-ability="{{id}}" data-delta="-1">−</button>{{/if}}<strong>{{value}}</strong>{{#if ../access.canConfigure}}<button type="button" data-action="adjustAbility" data-ability="{{id}}" data-delta="1">+</button>{{/if}}</div>{{/each}}</article>
    {{#if isHero}}<article class="panel"><h2>Origin</h2><label>Species<select name="system.speciesId" {{#if system.build.locked}}disabled{{/if}}>{{#each speciesOptions}}<option value="{{id}}" {{#if (a2eEq id ../system.speciesId)}}selected{{/if}}>{{name}}</option>{{/each}}</select></label><label>Archetype<select name="system.archetypeId" {{#if system.build.locked}}disabled{{/if}}><option value="">Choose…</option>{{#each archetypeOptions}}<option value="{{id}}" {{#if (a2eEq id ../system.archetypeId)}}selected{{/if}}>{{name}}</option>{{/each}}</select></label><label>Mandated Talent<select name="system.mandatedTalentId" {{#if system.build.locked}}disabled{{/if}}><option value="">Choose…</option>{{#each mandatedOptions}}<option value="{{id}}" {{#if (a2eEq id ../system.mandatedTalentId)}}selected{{/if}}>{{name}}</option>{{/each}}</select></label></article>{{/if}}
    <article class="panel span-2"><h2>Skills <small>rank cap {{rankCap}} · {{system.build.skillPointsAvailable}} advancement points</small></h2>{{#each skillGroups}}<details open><summary>{{name}}</summary>{{#each rows}}<div class="skill-line"><button type="button" data-action="rollSkill" data-item-id="{{item.id}}">{{item.name}}</button><span>{{item.system.keyAbility}}</span><div class="a2e-mini-stepper">{{#if ../../access.canConfigure}}<button type="button" data-action="adjustRank" data-item-id="{{item.id}}" data-delta="-1">−</button>{{/if}}<strong>{{item.system.ranks}}</strong>{{#if ../../access.canConfigure}}<button type="button" data-action="adjustRank" data-item-id="{{item.id}}" data-delta="1">+</button>{{/if}}</div><span>Target {{target}}</span></div>{{/each}}</details>{{/each}}</article>
    <article class="panel span-2"><h2>Talent Constellations</h2>{{#each talents}}<details><summary>{{#if system.parentId}}↪{{else}}★{{/if}} {{name}}</summary><p>{{system.description}}</p><small>{{system.constellation}} · Core p. {{system.page}}</small></details>{{else}}<p>Use the Creator or drag talents from the compendium.</p>{{/each}}</article>
  </div></section>
  <section class="tab" data-group="primary" data-tab="items"><div class="sheet-toolbar"><button type="button" data-action="refreshSources">Refresh character Items</button><button type="button" data-action="consolidateItems">Consolidate duplicate Items</button>{{#if isGM}}<button type="button" data-action="rebuildCompendiums">Rebuild compendiums</button>{{/if}}</div>{{#if access.canInventory}}<div class="upgrade-installer"><select name="upgradeTarget">{{#each upgradeTargets}}<option value="{{id}}">{{name}}</option>{{/each}}</select><select name="upgradeSource">{{#each upgradeOptions}}<option value="{{system.sourceId}}">{{name}}</option>{{/each}}</select><button type="button" data-action="installUpgrade">Install upgrade</button></div>{{/if}}<p><b>Carried mass:</b> {{load.mass}} / {{load.capacity}} kg · {{load.label}}. Drag Items from any Alternity compendium onto this sheet.</p><div class="a2e-grid">{{#each equipmentGroups}}<article class="panel"><h2>{{name}}</h2>{{#each items}}<div class="item-line"><button type="button" data-action="editItem" data-item-id="{{id}}"><b>{{name}}</b></button><span>{{system.mass}} kg each</span><div class="quantity-control"><button type="button" data-action="adjustQuantity" data-item-id="{{id}}" data-delta="-1">−</button><b>{{system.quantity}}</b><button type="button" data-action="adjustQuantity" data-item-id="{{id}}" data-delta="1">+</button></div><button type="button" data-action="toggleEquip" data-item-id="{{id}}">{{#if system.equipped}}Equipped{{else}}Stowed{{/if}}</button><button type="button" data-action="deleteItem" data-item-id="{{id}}"><i class="fas fa-trash"></i></button></div><div class="item-benefit">{{system.description}}{{#if system.physical}} · Armor P{{system.physical}}/E{{system.energy}}{{/if}}{{#if system.special}} · {{system.special}}{{/if}}{{#if system.upgrades}} · Upgrades: {{system.upgrades}}{{/if}}</div>{{/each}}</article>{{/each}}</div><article class="panel"><h2>Damage Log</h2>{{#each system.play.damageLog}}<div class="item-line">{{raw}} {{type}} − {{resistance}} = <b>{{final}} {{severity}}</b></div>{{else}}<p>No damage recorded.</p>{{/each}}</article></section>
  <section class="tab" data-group="primary" data-tab="advance"><article class="panel"><h2>Advancement</h2><p>The GM awards levels. An open advancement grants tracked skill points and a validated talent choice.</p><p><b>{{system.build.skillPointsAvailable}}</b> skill points and <b>{{system.build.talentChoicesAvailable}}</b> talent choices remain.</p>{{#if access.isGM}}<button type="button" data-action="advanceLevel" {{#if (a2eEq system.level 10)}}disabled{{/if}}>Award level {{a2eAdd system.level 1}}</button><button type="button" data-action="openAdvancement">Open advancement</button>{{/if}}{{#each system.advancement}}<div class="item-line"><b>Level {{level}}</b><span>+{{skillPoints}} skill points · +{{talentChoices}} talent</span></div>{{/each}}</article></section>
  <section class="tab" data-group="primary" data-tab="notes"><label>Background<textarea name="system.identity.background">{{system.identity.background}}</textarea></label><label>Goals<textarea name="system.identity.goals">{{system.identity.goals}}</textarea></label><label>Connections<textarea name="system.identity.connections">{{system.identity.connections}}</textarea></label><label>Notes<textarea name="system.identity.notes">{{system.identity.notes}}</textarea></label></section>
</form>
