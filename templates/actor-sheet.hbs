<form class="{{cssClass}} a2e-sheet" autocomplete="off">
  <header class="a2e-header"><img src="{{actor.img}}" data-edit="img" title="{{actor.name}}"><div><input class="a2e-name" name="name" value="{{actor.name}}"><p>Level {{system.level}} · {{actor.type}} · TE {{system.campaign.techEra}}</p></div><div class="header-actions"><button type="button" data-action="creationWizard"><i class="fas fa-list-check"></i> Creator</button><button type="button" data-action="importCharacter"><i class="fas fa-file-import"></i> Import</button><button type="button" data-action="exportCharacter"><i class="fas fa-file-export"></i> Export</button></div></header>
  <section class="a2e-summary"><div><strong>{{system.derived.initiative.target}}</strong>Initiative target</div><div><strong>{{system.derived.speed}} m</strong>Current speed</div><div><strong>{{system.derived.woundPenalty}}</strong>Wound steps</div><div><strong>{{system.derived.armor.physical}} / {{system.derived.armor.energy}}</strong>Armor P/E</div></section>
  <nav class="tabs" data-group="primary"><a class="item" data-tab="play">Play</a><a class="item" data-tab="build">Character</a><a class="item" data-tab="items">Items</a><a class="item" data-tab="advance">Advancement</a><a class="item" data-tab="notes">Notes</a></nav>
  <section class="tab" data-group="primary" data-tab="play"><div class="a2e-grid">
    <article class="panel"><h2>Round {{system.play.round}} · Impulse {{system.play.impulse}}/8</h2><p>When a Foundry encounter is active, this follows the shared Impulse Combat Tracker.</p><button type="button" data-action="nextImpulse">Advance impulse</button><button type="button" data-action="newScene">New scene</button><h3>Hero Points</h3><div class="counter"><button type="button" data-action="heroDown">−</button><strong>{{system.heroPoints}}</strong><button type="button" data-action="heroUp">+</button></div></article>
    <article class="panel"><h2>Apply Damage</h2><div class="damage-form"><input name="damage" type="number" min="0" value="0"><select name="damageType"><option value="physical">Physical</option><option value="energy">Energy</option><option value="other">Other</option></select><button type="button" data-action="applyDamage">Apply</button></div>{{#if system.play.lastDamage}}<p>{{system.play.lastDamage.raw}} − {{system.play.lastDamage.resistance}} armor = <strong>{{system.play.lastDamage.final}} {{system.play.lastDamage.severity}}</strong></p>{{/if}}<div class="recovery-actions"><button type="button" data-action="recover" data-period="scene">Clear grazes</button><button type="button" data-action="recover" data-period="day">Clear lights</button></div></article>
    <article class="panel wounds span-2"><h2>Armor and Damage</h2><p>Armor reduces physical by <b>{{system.derived.armor.physical}}</b>, energy by <b>{{system.derived.armor.energy}}</b>.</p>{{#each wounds}}<div class="wound-row"><b>{{range}}</b><span>{{label}}</span><span>{{#each boxes}}<button type="button" class="wound-box {{#if marked}}marked{{/if}}" data-action="toggleWound" data-row="{{../id}}" data-index="{{index}}"></button>{{/each}}</span></div>{{/each}}</article>
    <article class="panel"><h2>Attacks</h2>{{#each attacks}}<div class="attack-row {{#unless system.equipped}}unequipped{{/unless}}"><button type="button" class="item-roll" data-action="rollWeapon" data-item-id="{{id}}"><span><b>{{name}}</b><small>{{system.range}} · Speed {{system.speed}} · {{system.special}}</small></span><span>{{system.damage}} {{system.damageType}}</span></button>{{#if system.ammo.max}}<div class="ammo"><span>Ammo {{system.ammo.value}}/{{system.ammo.max}}</span><button type="button" data-action="reload" data-item-id="{{id}}" data-speed="{{system.speed}}">Reload</button></div>{{/if}}</div>{{else}}<p>Drag weapons here from the Weapons compendium.</p>{{/each}}</article>
    <article class="panel"><h2>Conditions</h2><div class="status-grid">{{#each statuses}}<button type="button" class="status {{#if active}}active{{/if}}" data-action="toggleStatus" data-status="{{id}}">{{label}}</button>{{/each}}</div></article>
    <article class="panel span-2"><h2>Skill Checks</h2>{{#each skillGroups}}<details open><summary>{{name}}</summary>{{#each rows}}<button type="button" class="item-roll" data-action="rollSkill" data-item-id="{{item.id}}"><span><b>{{item.name}}</b><small>{{item.system.keyAbility}} · {{item.system.ranks}} ranks</small></span><span>Target {{target}} · {{steps}} steps</span></button>{{/each}}</details>{{/each}}</article>
  </div></section>
  <section class="tab" data-group="primary" data-tab="build"><div class="a2e-grid">
    <article class="panel"><h2>Abilities</h2>{{#each abilities}}<div class="a2e-stepper"><span>{{label}}</span><button type="button" data-action="adjustAbility" data-ability="{{id}}" data-delta="-1">−</button><strong>{{value}}</strong><button type="button" data-action="adjustAbility" data-ability="{{id}}" data-delta="1">+</button></div>{{/each}}</article>
    <article class="panel"><h2>Origin</h2><label>Species<select name="system.speciesId">{{#each speciesOptions}}<option value="{{id}}" {{#if (a2eEq id ../system.speciesId)}}selected{{/if}}>{{name}}</option>{{/each}}</select></label><label>Archetype<select name="system.archetypeId"><option value="">Choose…</option>{{#each archetypeOptions}}<option value="{{id}}" {{#if (a2eEq id ../system.archetypeId)}}selected{{/if}}>{{name}}</option>{{/each}}</select></label><label>Mandated Talent<select name="system.mandatedTalentId"><option value="">Choose…</option>{{#each mandatedOptions}}<option value="{{id}}" {{#if (a2eEq id ../system.mandatedTalentId)}}selected{{/if}}>{{name}}</option>{{/each}}</select></label></article>
    <article class="panel span-2"><h2>Skills <small>rank cap {{rankCap}}</small></h2>{{#each skillGroups}}<details open><summary>{{name}}</summary>{{#each rows}}<div class="skill-line"><button type="button" data-action="rollSkill" data-item-id="{{item.id}}">{{item.name}}</button><span>{{item.system.keyAbility}}</span><div class="a2e-mini-stepper"><button type="button" data-action="adjustRank" data-item-id="{{item.id}}" data-delta="-1">−</button><strong>{{item.system.ranks}}</strong><button type="button" data-action="adjustRank" data-item-id="{{item.id}}" data-delta="1">+</button></div><span>Target {{target}}</span></div>{{/each}}</details>{{/each}}</article>
    <article class="panel span-2"><h2>Talent Constellations</h2>{{#each talents}}<details><summary>{{#if system.parentId}}↪{{else}}★{{/if}} {{name}}</summary><p>{{system.description}}</p><small>{{system.constellation}} · Core p. {{system.page}}</small></details>{{else}}<p>Use the Creator or drag talents from the compendium.</p>{{/each}}</article>
  </div></section>
  <section class="tab" data-group="primary" data-tab="items"><div class="sheet-toolbar"><button type="button" data-action="refreshSources">Refresh character Items</button>{{#if isGM}}<button type="button" data-action="rebuildCompendiums">Rebuild compendiums</button>{{/if}}</div><p>Drag Items from any Alternity compendium onto this sheet.</p><div class="a2e-grid">{{#each equipmentGroups}}<article class="panel"><h2>{{name}}</h2>{{#each items}}<div class="item-line"><button type="button" data-action="editItem" data-item-id="{{id}}"><b>{{name}}</b></button><span>{{system.mass}} kg</span><button type="button" data-action="toggleEquip" data-item-id="{{id}}">{{#if system.equipped}}Equipped{{else}}Stowed{{/if}}</button><button type="button" data-action="deleteItem" data-item-id="{{id}}"><i class="fas fa-trash"></i></button></div><div class="item-benefit">{{system.description}}{{#if system.physical}} · Armor P{{system.physical}}/E{{system.energy}}{{/if}}{{#if system.special}} · {{system.special}}{{/if}}</div>{{/each}}</article>{{/each}}</div><article class="panel"><h2>Damage Log</h2>{{#each system.play.damageLog}}<div class="item-line">{{raw}} {{type}} − {{resistance}} = <b>{{final}} {{severity}}</b></div>{{else}}<p>No damage recorded.</p>{{/each}}</article></section>
  <section class="tab" data-group="primary" data-tab="advance"><article class="panel"><h2>Advancement</h2><p>Each level grants 5 skill points and one talent choice. Use the rank controls and drag the new talent from its compendium after advancing.</p><button type="button" data-action="advanceLevel" {{#if (a2eEq system.level 10)}}disabled{{/if}}>Advance to level {{a2eAdd system.level 1}}</button>{{#each system.advancement}}<div class="item-line"><b>Level {{level}}</b><span>+{{skillPoints}} skill points · +{{talentChoices}} talent</span></div>{{/each}}</article></section>
  <section class="tab" data-group="primary" data-tab="notes"><label>Background<textarea name="system.identity.background">{{system.identity.background}}</textarea></label><label>Goals<textarea name="system.identity.goals">{{system.identity.goals}}</textarea></label><label>Connections<textarea name="system.identity.connections">{{system.identity.connections}}</textarea></label><label>Notes<textarea name="system.identity.notes">{{system.identity.notes}}</textarea></label></section>
</form>
