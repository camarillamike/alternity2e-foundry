<form class="{{cssClass}} a2e-sheet" autocomplete="off"><header class="a2e-header"><img src="{{item.img}}" data-edit="img"><input class="a2e-name" name="name" value="{{item.name}}"></header><div class="a2e-grid"><article class="panel"><label>Source ID<input name="system.sourceId" value="{{system.sourceId}}"></label><label>Page<input type="number" name="system.page" value="{{system.page}}"></label><label>Quantity<input type="number" name="system.quantity" value="{{system.quantity}}"></label><label>Mass<input type="number" step="0.1" name="system.mass" value="{{system.mass}}"></label><label>Damage<input name="system.damage" value="{{system.damage}}"></label><label>Damage Type<input name="system.damageType" value="{{system.damageType}}"></label><label>Range<input name="system.range" value="{{system.range}}"></label><label>Speed<input type="number" name="system.speed" value="{{system.speed}}"></label><label>Physical<input type="number" name="system.physical" value="{{system.physical}}"></label><label>Energy<input type="number" name="system.energy" value="{{system.energy}}"></label></article>{{#if (a2eEq item.type "weapon")}}<article class="panel"><h2>Ammunition</h2><label>Mode<input name="system.ammo.mode" value="{{system.ammo.mode}}"></label><label>Loaded<input type="number" min="0" name="system.ammo.value" value="{{system.ammo.value}}"></label><label>Capacity<input type="number" min="0" name="system.ammo.max" value="{{system.ammo.max}}"></label><label>Reload impulses<input type="number" min="0" name="system.ammo.reloadCost" value="{{system.ammo.reloadCost}}"></label><label>Loaded per reload<input type="number" min="0" name="system.ammo.reloadAmount" value="{{system.ammo.reloadAmount}}"></label><label>Reserve<input type="number" min="0" name="system.ammo.reserve" value="{{system.ammo.reserve}}"></label><label>Reserve unit<input name="system.ammo.reserveUnit" value="{{system.ammo.reserveUnit}}"></label><label>Payload<input name="system.ammo.payload" value="{{system.ammo.payload}}"></label><label>Special ammunition<select name="system.ammo.specialType"><option value="normal" {{#if (a2eEq system.ammo.specialType "normal")}}selected{{/if}}>Normal</option><option value="armorPiercing" {{#if (a2eEq system.ammo.specialType "armorPiercing")}}selected{{/if}}>Armor Piercing</option><option value="hollowPoint" {{#if (a2eEq system.ammo.specialType "hollowPoint")}}selected{{/if}}>Hollow Point</option><option value="incendiary" {{#if (a2eEq system.ammo.specialType "incendiary")}}selected{{/if}}>Incendiary</option><option value="detoMax" {{#if (a2eEq system.ammo.specialType "detoMax")}}selected{{/if}}>Deto-Max</option></select></label><label><input type="checkbox" name="system.ammo.specialAvailable" {{#if system.ammo.specialAvailable}}checked{{/if}}> Special-ammunition supply available</label><label><input type="checkbox" name="system.ammo.speedLoader" {{#if system.ammo.speedLoader}}checked{{/if}}> Revolver speed loader</label></article>{{/if}}<article class="panel"><label>Description<textarea name="system.description">{{system.description}}</textarea></label></article></div></form>
