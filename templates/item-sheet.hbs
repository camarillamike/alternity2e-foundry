<form class="{{cssClass}} a2e-sheet" autocomplete="off"><header class="a2e-header"><img src="{{item.img}}" data-edit="img"><input class="a2e-name" name="name" value="{{item.name}}"></header><div class="a2e-grid"><article class="panel"><label>Source ID<input name="system.sourceId" value="{{system.sourceId}}"></label><label>Page<input type="number" name="system.page" value="{{system.page}}"></label><label>Quantity<input type="number" name="system.quantity" value="{{system.quantity}}"></label><label>Mass<input type="number" step="0.1" name="system.mass" value="{{system.mass}}"></label><label>Damage<input name="system.damage" value="{{system.damage}}"></label><label>Damage Type<input name="system.damageType" value="{{system.damageType}}"></label><label>Range<input name="system.range" value="{{system.range}}"></label><label>Speed<input type="number" name="system.speed" value="{{system.speed}}"></label><label>Physical<input type="number" name="system.physical" value="{{system.physical}}"></label><label>Energy<input type="number" name="system.energy" value="{{system.energy}}"></label></article><article class="panel"><label>Description<textarea name="system.description">{{system.description}}</textarea></label></article></div></form>
