{
  "id": "alternity2e",
  "title": "Alternity 2e (Private System)",
  "description": "A private-use Foundry VTT implementation of Alternity 2e with character creation, rolls, wounds, armor, talents, gear, and impulse combat support.",
  "version": "0.3.1",
  "compatibility": { "minimum": 13, "verified": 14 },
  "authors": [{ "name": "Private campaign system" }],
  "esmodules": ["alternity2e.mjs"],
  "styles": ["styles/alternity2e.css", "styles/combat.css", "styles/inventory.css"],
  "languages": [{ "lang": "en", "name": "English", "path": "lang/en.json" }],
  "documentTypes": {
    "Actor": { "hero": {}, "npc": {}, "creature": {}, "drone": {}, "vehicle": {} },
    "Item": { "skill": {}, "talent": {}, "weapon": {}, "armor": {}, "tool": {}, "gear": {}, "upgrade": {}, "species": {}, "archetype": {}, "condition": {} }
  },
  "initiative": "1d20",
  "grid": { "distance": 2, "units": "m" },
  "primaryTokenAttribute": "wounds.mortal",
  "secondaryTokenAttribute": "heroPoints",
  "socket": true,
  "url": "https://github.com/camarillamike/alternity2e-foundry",
  "manifest": "https://raw.githubusercontent.com/camarillamike/alternity2e-foundry/main/system.json",
  "download": "https://github.com/camarillamike/alternity2e-foundry/releases/download/v0.3.1/alternity2e-foundry-v0.3.1.zip"
}
